VITE_APP_NAME=CreditClear
VITE_APP_ENV=development
VITE_APP_URL=http://localhost:5173
# Production: set to your real site (https://www.creditclearai.com). Used by /api CORS fallbacks.
# Public canonical URL for OG / JSON-LD (optional; defaults to https://www.creditclearai.com)
VITE_SITE_URL=https://www.creditclearai.com
# After verifying in Google Search Console, paste the content token here (injected into <head> at runtime via /env.js).
# VITE_GOOGLE_SITE_VERIFICATION=your_token_from_google
# Optional X/Twitter handle without @ (optional).
# VITE_TWITTER_SITE=creditclearai
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_SENTRY_DSN=
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

APP_URL=http://localhost:5173
# Railway Node server: canonical origin for redirects, sitemap, and crawler HTML (default https://www.creditclearai.com).
# PUBLIC_SITE_ORIGIN=https://www.creditclearai.com
# Comma-separated browser origins allowed to call /api/* (include https://www.yourdomain.com and apex if you use both).
ALLOWED_ORIGINS=http://localhost:5173
# Railway/Node: VITE_SUPABASE_* must match this project. The app serves /env.js so the browser picks up
# VITE_* from process.env at runtime (you can change vars without rebuilding if the image already includes this server).
#
# Free-tier projects can auto-pause; paid plans stay warm. If you still see slow first auth, check project status in Supabase.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Primary ops login: use ONE email everywhere (Supabase /login, Railway below, optional team list).
# ADMIN_EMAIL always gets complimentary app access (same as OWNER_FREE_ACCESS_EMAILS entries).
# Set ADMIN_PASSWORD, then run: npm run auth:sync-admin  (or railway run npm run auth:sync-admin)
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# Extra team emails (comma-separated) that get complimentary access without being ADMIN_EMAIL:
OWNER_FREE_ACCESS_EMAILS=

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

AI_API_KEY=sk-proj-...
AI_MODEL_NAME=gpt-4.1-mini

# Optional provider-specific alias
ANTHROPIC_API_KEY=sk-ant-...
